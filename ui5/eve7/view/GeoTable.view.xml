<mvc:View
    controllerName="rootui5.eve7.controller.GeoTable"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
    xmlns:t="sap.ui.table"
    height="100%">
    <Toolbar id="tbar">
      <content>
         <Label text="GeoTable" id="titleLabel" width="100%" textAlign="Center"/>
         <Button icon="sap-icon://move" press="switchSingle" tooltip="single view"/>
         <Button icon="sap-icon://arrow-right" press="swap" tooltip="swap"/>
         <Button icon="sap-icon://decline" press="detachViewer" tooltip="destroy"/>
      </content>
    </Toolbar>
   <FlexBox height="100%" direction="Column">
      <Toolbar>
         <layoutData>
            <FlexItemData baseSize="35px"/>
         </layoutData>

         <Button icon="sap-icon://synchronize" type="Transparent"
                 tooltip="Reload geometry hierarchy" press="onRealoadPress"/>

         <Button text="cdTop" type="Transparent"
                 tooltip="Reload geometry hierarchy" press="cdTop"/>
         <Button text="cdUp" type="Transparent"
                 tooltip="Reload geometry hierarchy" press="cdUp"/>
         <ToolbarSpacer />
         <SearchField id="searchNode" liveChange="onSearch"
                      tooltip="Type regexp for name or material with prefix m:"/>
      </Toolbar>
      <t:TreeTable
         id="treeTable"
         columnHeaderVisible="false"
         editable="false"
         enableSelectAll="false"
         selectionBehavior="RowOnly"
         selectionMode="Single"
         visibleRowCountMode="Auto"
         cellClick="onCellClick"
         cellContextmenu="onCellContextMenu"
         rows="{/nodes}">
         <t:layoutData>
            <FlexItemData growFactor="1"/>
         </t:layoutData>
      </t:TreeTable>
   </FlexBox>
    <!--mvc:XMLView id="geomHierarchyPanel" width="100%"
      height="100%" viewName="rootui5.geom.view.GeomHierarchy">
    </mvc:XMLView-->
</mvc:View>
