# -*- mode: makefile -*-
#
# Makefile compiler definitions included by the top Makefile.
# Used to override the compilers specified in the architecture
# specific Makefiles.

CC    = @altcc@
CXX   = @altcxx@
F77   = @altf77@
LD    = @altld@
GCCTOOLCHAIN = @gcctoolchain@

$(warning The use of Makefiles is deprecated in ROOT 6.42 and will be removed in a future release.)
