--- /dev/null	2026-03-12 08:23:04
+++ CMakeLists.txt	2026-03-12 08:20:11
@@ -0,0 +1,29 @@
+cmake_minimum_required(VERSION 3.23)
+project(LibUngif VERSION 1.0) # The version does not matter here
+
+add_library(gif-static STATIC
+    dgif_lib.c
+    egif_lib.c
+    gif_err.c
+    gif_hash.c
+    gifalloc.c
+    openbsd-reallocarray.c
+)
+
+target_sources(gif-static PUBLIC
+    FILE_SET HEADERS
+    BASE_DIRS ./
+    FILES gif_lib.h gif_hash.h
+)
+
+if(NOT MSVC)
+    target_compile_options(gif-static PRIVATE -std=gnu99 -fPIC -Wall -Wno-format-truncation)
+endif()
+
+target_include_directories(gif-static PUBLIC ./)
+
+# Install the target and its file sets
+install(TARGETS gif-static
+    FILE_SET HEADERS DESTINATION ${CMAKE_INSTALL_PREFIX}/include
+    ARCHIVE DESTINATION ${CMAKE_INSTALL_PREFIX}/lib
+)
